      "repeat_id": 305847,
      "resource_id": 25,
      "resource_area_id": 40,
      "desc": "OIC - Summer Half Day Camp July 20-24",
      "event_type_id": "c",
      "sub_type": "regular",
      "start": "2026-07-20T10:30:00",
      "start_gmt": "2026-07-20T17:30:00",
      "end": "2026-07-20T11:30:00",
      "end_gmt": "2026-07-20T18:30:00",
      "customer_id": 0,
      "hteam_id": 9876,
      "vteam_id": null,
      "league_id": null,
      "home_score": null,
      "visiting_score": null,
      "publish": true,
      "outcome": "",
      "register_capacity": 0,
      "create_u": "ssimon",
      "created_user_type": "SIT_Employee",
      "create_d": "2026-05-19T13:10:54",
      "mod_u": "ssimon",
      "last_modified_user_type": "SIT_Employee",
      "mod_d": "2026-05-22T12:21:39",
      "is_overtime": false,
      "booking_id": 0,
      "description": null,
      "notice": null,
      "last_resource_id": null,
      "parent_event_id": null,
      "has_gender_locker_rooms": 0,
      "locker_room_type": null,
      "includes_setup_time": false,
      "includes_takedown_time": false,
      "start_date": "2026-07-20T00:00:00",
      "event_start_time": "10:30:00",
      "best_description": "<p><strong>SUMMER HALF DAY CAMPS 2026<br /></strong></p>\n<p>Beginner 1 to Intermediate 3 Learn to Skate Skill Levels</p>\n<p><strong>(Ages 6 and up)</strong></p>\n<p>Our camps provide children at the Beginning and Intermediate levels the opportunity to skate,</p>\n<p>play and grow in a positive, fun, and safe atmosphere.<br /><br /></p>\n<ul>\n<li>All Skating Class students should wear warm clothing, gloves, long socks and clothes that allow them to move easily on the ice.</li>\n<li>Please be patient with the staff and the skaters on the first day. We are doing our best to ensure that everyone in the camp is safe, happy and having fun.</li>\n<li>Please do not block the doors to the ice. It impedes the flow of traffic for the skaters and coaches entering and exiting AND can be quite dangerous too. The doors should be closed at all times.</li>\n<li>Please do not interrupt the instructors while they are working.</li>\n<li><strong>No Parents/Caregivers are allowed on the party room. Thank you.</strong></li>\n<li>Spectators can view from the bleachers upstairs.</li>\n</ul>\n<p><strong>Daily Day Camp Schedule:</strong></p>\n<p>(All activities are supervised by Oakland Ice Center Instructors)</p>\n<ul>\n<li>10:00 - AM - Drop Off and Skater Check In (Earlier drop off is not available)</li>\n<li>10:15 - Off Ice Warm Up (Running shoes please) then Skates On</li>\n<li>10:30 - On Ice with lesson</li>\n<li>11:15 - Snack (bring your own snack/water or purchase at our snack bar)</li>\n<li>11:30 - Free skate/practice with supervision</li>\n<li>12:30 - Exit the ice &ndash; skates off &ndash; Off Ice Warm Down</li>\n<li>1:00 PM - Pick Up Your Camper - On time please! Late pick ups will result in an extra fee.</li>\n</ul>\n<p><u><strong>NO REFUNDS OR EXCHANGES</strong></u></p>"
    }
  },
